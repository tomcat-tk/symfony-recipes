{
    "packages": {
        "tomcat-tk/external-api": {
            "1.0": {
                "name": "tomcat-tk/external-api",
                "version": "1.0",
                "recipe": {
                    "bundles": {
                        "ExternalApi\\Bridge\\Symfony\\ExternalApiBundle": [
                            "all"
                        ]
                    },
                    "files": {
                        "config/packages/external_api.yaml": {
                            "contents": [
                                "external_api:",
                                "    url: '%env(EXTERNAL_API_URL)%'",
                                "    key: '%env(EXTERNAL_API_KEY)%'"
                            ]
                        }
                    },
                    "post-install-output": [
                        "External API Bundle installed.",
                        "Configure EXTERNAL_API_URL and EXTERNAL_API_KEY in your .env file."
                    ]
                }
            }
        }
    }
}